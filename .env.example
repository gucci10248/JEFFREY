# BioMCP Environment Variables
# Copy this to .env and fill in your keys.
# All keys are OPTIONAL — the server runs without them, but some features are gated.

# NCBI E-utilities API key — boosts PubMed rate from 3/sec to 10/sec
# Get one free at: https://account.ncbi.nlm.nih.gov/settings/
NCBI_API_KEY=

# Semantic Scholar API key — paper recommendations & citation search
# Get one free at: https://api.semanticscholar.org/
S2_API_KEY=

# OncoKB token — clinical variant annotations for cancer genomics
# Register at: https://www.oncokb.org/account/register
ONCOKB_TOKEN=

# NCI Clinical Trials Search API key
# Register at: https://clinicaltrialsapi.cancer.gov/
NCI_API_KEY=

# DisGeNET API key — gene-disease association database
# Get one free at: https://www.disgenet.org/
DISGENET_API_KEY=

# UMLS API key — Unified Medical Language System
# Register at: https://uts.nlm.nih.gov/uts/
UMLS_API_KEY=

# AlphaGenome API key — variant annotation
# Register at: https://alphagenome.com/
ALPHAGENOME_API_KEY=

# Unpaywall email — enables full-text PDF fallback for OA articles
UNPAYWALL_EMAIL=
